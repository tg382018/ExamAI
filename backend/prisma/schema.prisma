generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  passwordHash     String
  name             String
  createdAt        DateTime      @default(now())
  isVerified       Boolean       @default(false)
  verificationCode String?
  attempts         Attempt[]
  deviceTokens     DeviceToken[]
  exams            Exam[]
  autoPilotConfig  AutoPilotConfig?
}

model AutoPilotConfig {
  id            String   @id @default(uuid())
  userId        String   @unique
  isActive      Boolean  @default(false)
  frequency     String   @default("daily")
  time          String   @default("09:00") // HH:mm format
  topic         String?
  subtopic      String?
  level         String?
  difficulty    String?
  questionCount Int      @default(10)
  type          String   @default("mixed")
  prompt        String?
  isPromptTab   Boolean  @default(false)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Exam {
  id            String     @id @default(uuid())
  userId        String
  title         String
  prompt        String
  status        ExamStatus @default(QUEUED)
  durationMin   Int
  questionCount Int
  difficulty    String     @default("mixed")
  aiSummary     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  isAuto        Boolean    @default(false)
  attempts      Attempt[]
  user          User       @relation(fields: [userId], references: [id])
  questions     Question[]
}

model Question {
  id            String       @id @default(uuid())
  examId        String
  type          QuestionType @default(MULTIPLE_CHOICE)
  orderIndex    Int
  text          String
  options       Json // Empty for OPEN_ENDED, [True, False] for TRUE_FALSE
  correctOption Int? // Index for MCQ/TF
  correctAnswer String? // Text for OPEN_ENDED
  explanation   String
  difficulty    String       @default("medium")
  topicTag      String       @default("")
  asciiArt      String?
  exam          Exam         @relation(fields: [examId], references: [id])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  OPEN_ENDED
}

model Attempt {
  id           String    @id @default(uuid())
  examId       String
  userId       String
  answers      Json
  score        Float?
  correctCount Int?
  wrongCount   Int?
  emptyCount   Int?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  exam         Exam      @relation(fields: [examId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum ExamStatus {
  QUEUED
  GENERATING
  READY
  FAILED
}
